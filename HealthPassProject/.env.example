# MongoDB connection string (MongoDB Atlas or local)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.mongodb.net/healthpass?retryWrites=true&w=majority"

# JWT secrets (use a long random string each)
JWT_ACCESS_SECRET="change_this_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_min_32_chars"

# Token expiry
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=5000
NODE_ENV=development

# File upload directory (relative to backend root)
UPLOAD_DIR="uploads"

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=10

# Max OTP attempts before block
OTP_MAX_ATTEMPTS=5
